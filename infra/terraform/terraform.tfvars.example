name_prefix                    = "schoolai"
environment                    = "dev"
location                       = "westeurope"
search_sku                     = "basic"
backend_image_tag              = "latest"
allowed_origins                = ["http://localhost:5173", "https://school.example.nl"]

# Azure AI Foundry – model deployments (provisioned via Terraform)
chat_model_deployment_name      = "gpt-4o-mini"
chat_model_name                 = "gpt-4o-mini"
chat_model_version              = "2024-07-18"
chat_model_capacity             = 10
embedding_model_deployment_name = "text-embedding-3-large"
embedding_model_name            = "text-embedding-3-large"
embedding_model_version         = "1"
embedding_model_capacity        = 10